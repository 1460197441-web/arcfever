page {
  min-height: 100%;
  background:
    radial-gradient(circle at 20% 0%, rgba(57, 178, 181, 0.2), transparent 26%),
    radial-gradient(circle at 100% 20%, rgba(13, 87, 145, 0.18), transparent 24%),
    linear-gradient(180deg, #eef7fb 0%, #f7fbfd 46%, #eef4f8 100%);
  color: #14304a;
  font-family: "HarmonyOS Sans SC", "PingFang SC", sans-serif;
}

.page-shell {
  padding: 28rpx 24rpx 88rpx;
}

.hero-panel {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 34rpx 30rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.02)),
    linear-gradient(135deg, #0b2440 0%, #155b91 55%, #24a8ad 100%);
  color: #ffffff;
  box-shadow: 0 26rpx 60rpx rgba(11, 54, 92, 0.24);
}

.hero-panel::before {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-panel::after {
  content: "";
  position: absolute;
  left: -70rpx;
  bottom: -90rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-tag {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
}

.hero-title {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-copy {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.86);
}

.hero-actions {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 26rpx;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #102d47;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7690a7;
}

.card {
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(18, 64, 99, 0.05);
  box-shadow: 0 14rpx 40rpx rgba(20, 48, 74, 0.08);
}

.glass-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.68);
  backdrop-filter: blur(18px);
  border: 1rpx solid rgba(255, 255, 255, 0.46);
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(21, 91, 145, 0.08);
  color: #155b91;
  font-size: 22rpx;
}

.chip.active {
  background: linear-gradient(135deg, #155b91 0%, #24a8ad 100%);
  color: #ffffff;
}

.primary-btn,
.ghost-btn,
.light-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 600;
}

.primary-btn {
  background: linear-gradient(135deg, #24a8ad 0%, #155b91 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(20, 87, 138, 0.26);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.light-btn {
  background: rgba(21, 91, 145, 0.08);
  color: #155b91;
}

.nav-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.back-btn,
.float-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #155b91;
  font-size: 34rpx;
  box-shadow: 0 12rpx 30rpx rgba(20, 48, 74, 0.08);
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 86rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(20, 48, 74, 0.07);
}

.search-input {
  flex: 1;
  font-size: 27rpx;
}

.feature-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #13334d;
}

.feature-copy {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: #5f7b93;
}

.feature-price,
.badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(21, 91, 145, 0.09);
  color: #155b91;
  font-size: 22rpx;
  white-space: nowrap;
}

.meta-text {
  margin-top: 12rpx;
  font-size: 23rpx;
  color: #7c95aa;
}

.metric-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.metric-item {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
}

.metric-value {
  font-size: 30rpx;
  font-weight: 700;
  color: inherit;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: inherit;
  opacity: 0.82;
}

.panel {
  padding: 28rpx;
}

.form-label {
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #5f7b93;
}

.form-input,
.form-textarea,
.picker-box {
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f4f9fc;
  font-size: 26rpx;
  color: #16344f;
}

.form-textarea {
  min-height: 180rpx;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.full-btn {
  width: 100%;
  margin-top: 26rpx;
}

.empty-state,
.loading-state {
  padding: 56rpx 28rpx;
  text-align: center;
  color: #7992a8;
  font-size: 25rpx;
}

.footer-gap {
  height: 24rpx;
}
