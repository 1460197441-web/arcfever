<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="search-box">
      <view>搜</view>
      <input class="search-input" placeholder="搜索仪器、学校、标签" bindinput="onKeywordInput" />
    </view>
  </view>

  <view class="hero-panel compact-hero">
    <view class="hero-tag">仪器广场</view>
    <view class="hero-title small-title">按分类检索已认证用户发布的仪器</view>
    <view class="hero-copy">你可以通过分类、学校或关键词快速定位需要的设备，进入详情后可加入购物车或联系卖家。</view>
  </view>

  <view class="section">
    <view class="chip-row">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="chip {{activeCategory === item ? 'active' : ''}}"
        data-category="{{item}}"
        bindtap="chooseCategory"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">正在获取仪器列表...</view>
  <view wx:elif="{{!list.length}}" class="empty-state">当前条件下没有仪器。</view>

  <view wx:else class="section list-stack">
    <view class="card instrument-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="openInstrument">
      <view class="feature-top">
        <view>
          <view class="feature-title">{{item.name}}</view>
          <view class="meta-text">{{item.location}} · {{item.sellerName}}</view>
        </view>
        <view class="feature-price">{{item.priceLabel}}</view>
      </view>
      <view class="feature-copy">{{item.desc}}</view>
      <view class="chip-row">
        <view class="chip" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="meta-text">{{item.school}} / {{item.college}}</view>
    </view>
  </view>

  <view class="floating-cart" bindtap="goCart">购物车</view>
</view>
