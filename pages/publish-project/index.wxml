<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view class="hero-panel">
    <view class="hero-title small">发布科研协作需求</view>
    <view class="hero-copy">面向企业、团队和项目负责人，快速描述技术需求，平台将基于人才评估体系完成初步撮合。</view>
  </view>

  <view class="section">
    <view class="card panel">
      <view class="form-label">项目标题</view>
      <input class="form-input" placeholder="例如：近岸观测数据建模项目" data-field="title" bindinput="onInput" />
      <view class="form-label">发起单位</view>
      <input class="form-input" placeholder="填写企业或机构名称" data-field="company" bindinput="onInput" />
      <view class="form-label">研究领域</view>
      <input class="form-input" placeholder="海洋、地质、材料、平台建设等" data-field="domain" bindinput="onInput" />
      <view class="form-label">预算区间</view>
      <input class="form-input" placeholder="例如：10-20 万" data-field="budget" bindinput="onInput" />
      <view class="form-label">期望周期</view>
      <input class="form-input" placeholder="例如：3 个月" data-field="duration" bindinput="onInput" />
      <view class="form-label">核心需求</view>
      <textarea class="form-textarea" placeholder="描述技术目标、交付标准、协作方式" data-field="needs" bindinput="onInput"></textarea>
      <view class="primary-btn full-btn" bindtap="submitProject">提交项目</view>
    </view>
  </view>
</view>
