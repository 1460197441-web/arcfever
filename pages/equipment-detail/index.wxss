.detail-shell {
  padding-bottom: 180rpx;
}

.meta-line {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: #4d6c85;
}

.top-gap {
  margin-top: 18rpx;
}

.instrument-card {
  padding: 26rpx;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 30rpx;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 16rpx;
  padding: 14rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(20, 48, 74, 0.12);
}

.ghost-action,
.primary-action {
  min-height: 82rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 600;
}

.ghost-action {
  background: #eef6fb;
  color: #155b91;
}

.primary-action {
  background: linear-gradient(135deg, #24a8ad 0%, #155b91 100%);
  color: #ffffff;
}
