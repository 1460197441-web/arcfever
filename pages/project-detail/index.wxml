<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">正在加载项目详情...</view>

  <block wx:elif="{{project}}">
    <view class="hero-panel">
      <view class="feature-top">
        <view class="hero-title small">{{project.title}}</view>
        <view class="status-badge light">{{project.status}}</view>
      </view>
      <view class="detail-meta">{{project.domain}} · {{project.owner}}</view>
      <view class="hero-copy">{{project.intro}}</view>
      <view class="chip-row">
        <view class="chip detail-chip" wx:for="{{project.targetRoles}}" wx:key="*this">{{item}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">项目信息</view>
      </view>
      <view class="card panel">
        <view class="spec-row">
          <view class="spec-label">预算区间</view>
          <view class="spec-value">{{project.budget}}</view>
        </view>
        <view class="spec-row">
          <view class="spec-label">合作周期</view>
          <view class="spec-value">{{project.duration}}</view>
        </view>
        <view class="spec-row">
          <view class="spec-label">关键词</view>
          <view class="spec-value">{{keywordsText}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view>
          <view class="section-title">动态评估体系</view>
          <view class="section-subtitle">硬指标与软评价共同构成科研信用</view>
        </view>
      </view>
      <view class="card panel">
        <view class="assessment-card">
          <view class="assessment-label">硬指标</view>
          <view class="assessment-copy">{{project.evaluation.hard}}</view>
        </view>
        <view class="assessment-card">
          <view class="assessment-label">软评价</view>
          <view class="assessment-copy">{{project.evaluation.soft}}</view>
        </view>
        <view class="matrix-row" wx:for="{{matrix}}" wx:key="label">
          <view class="matrix-label">{{item.label}}</view>
          <view class="matrix-bar">
            <view class="matrix-fill" style="width: {{item.value}};"></view>
          </view>
          <view class="matrix-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">推荐人才</view>
      </view>
      <view class="list-stack">
        <view class="card talent-card" wx:for="{{project.matches}}" wx:key="name">
          <view class="feature-top">
            <view>
              <view class="feature-title">{{item.name}}</view>
              <view class="project-domain">{{item.title}}</view>
            </view>
            <view class="feature-price">{{item.score}} 分</view>
          </view>
          <view class="chip-row">
            <view class="chip" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">协作流程</view>
      </view>
      <view class="card panel">
        <view class="bullet-row" wx:for="{{flow}}" wx:key="*this">
          <view class="bullet-dot"></view>
          <view class="bullet-text">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="primary-btn full-btn" bindtap="contactPlatform">联系平台撮合</view>
  </block>
</view>
