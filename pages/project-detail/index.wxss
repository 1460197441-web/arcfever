.light {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.detail-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.assessment-card + .assessment-card {
  margin-top: 18rpx;
}

.assessment-label {
  font-size: 26rpx;
  font-weight: 700;
}

.assessment-copy {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #45627a;
}

.matrix-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.matrix-label {
  width: 170rpx;
  font-size: 24rpx;
  color: #5d7890;
}

.matrix-bar {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 74, 122, 0.08);
  overflow: hidden;
}

.matrix-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #17a8c2 0%, #0f6297 100%);
}

.matrix-value {
  width: 74rpx;
  text-align: right;
  font-size: 24rpx;
  color: #2d4a64;
}

.talent-card {
  padding: 28rpx;
}
