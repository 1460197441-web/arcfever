<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view class="hero-panel">
    <view class="hero-title small">AI 驱动的智能工具平台</view>
    <view class="hero-copy">当前版本将计划书中的专业算法能力转成可演示的工具台，适合答辩展示“数据输入 - 智能处理 - 结果回传”的完整流程。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view>
        <view class="section-title">选择工具</view>
        <view class="section-subtitle">重点覆盖地质、海洋与科研资源匹配场景</view>
      </view>
    </view>
    <view class="list-stack">
      <view
        wx:for="{{tools}}"
        wx:key="id"
        class="card tool-card {{currentToolId === item.id ? 'tool-card-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="chooseTool"
      >
        <view class="feature-top">
          <view class="feature-title">{{item.name}}</view>
          <view class="feature-price">{{item.mode}}</view>
        </view>
        <view class="feature-copy">{{item.subtitle}}</view>
        <view class="tool-outcome">{{item.outcome}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">提交分析任务</view>
    </view>
    <view class="card tool-card">
      <view class="form-label">分析目标</view>
      <input class="form-input" placeholder="例如：评估海岸带风暴潮风险" data-field="goal" bindinput="onInput" />
      <view class="form-label">数据说明</view>
      <textarea class="form-textarea" placeholder="填写数据来源、样本规模、关键变量或待解决问题" data-field="dataset" bindinput="onInput"></textarea>
      <view class="primary-btn full-btn" bindtap="submitTask">开始分析</view>
    </view>
  </view>

  <view wx:if="{{result}}" class="section">
    <view class="section-head">
      <view class="section-title">分析结果</view>
    </view>
    <view class="card tool-card">
      <view class="result-title">{{result.toolName}}</view>
      <view class="feature-copy">{{result.summary}}</view>
      <view class="metric-strip">
        <view class="metric-pill" wx:for="{{result.metrics}}" wx:key="label">
          <view class="metric-pill-value">{{item.value}}</view>
          <view class="metric-pill-label">{{item.label}}</view>
        </view>
      </view>
      <view class="bullet-row" wx:for="{{result.insights}}" wx:key="*this">
        <view class="bullet-dot"></view>
        <view class="bullet-text">{{item}}</view>
      </view>
    </view>
  </view>
</view>
