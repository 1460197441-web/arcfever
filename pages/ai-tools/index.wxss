.tool-card {
  padding: 28rpx;
}

.tool-card-active {
  background: linear-gradient(180deg, rgba(17, 74, 122, 0.08) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 1rpx solid rgba(17, 74, 122, 0.16);
}

.tool-outcome {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #11869c;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
}

.metric-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin: 22rpx 0;
}

.metric-pill {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f9fc;
}

.metric-pill-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f6297;
}

.metric-pill-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b8397;
}
