<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">正在加载个人中心...</view>

  <block wx:elif="{{profile}}">
    <view class="hero-panel">
      <view class="hero-tag">{{profile.certification.status}}</view>
      <view class="hero-title">{{profile.certification.name}}</view>
      <view class="hero-copy">{{profile.certification.school}} · {{profile.certification.college}}</view>
      <view class="metric-strip">
        <view class="metric-item">
          <view class="metric-value">{{profile.instrumentCount}}</view>
          <view class="metric-label">我的仪器</view>
        </view>
        <view class="metric-item">
          <view class="metric-value">{{profile.orderCount}}</view>
          <view class="metric-label">我的订单</view>
        </view>
        <view class="metric-item">
          <view class="metric-value">{{profile.favoriteCount}}</view>
          <view class="metric-label">我的收藏</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="grid-two">
        <view class="card menu-card" data-page="/pages/certification/index" bindtap="goPage">
          <view class="feature-title">认证信息</view>
          <view class="feature-copy">{{profile.certification.phone}}</view>
        </view>
        <view class="card menu-card" data-page="/pages/my-instruments/index" bindtap="goPage">
          <view class="feature-title">我发布的</view>
          <view class="feature-copy">管理个人设备</view>
        </view>
        <view class="card menu-card" data-page="/pages/order-list/index" bindtap="goPage">
          <view class="feature-title">订单列表</view>
          <view class="feature-copy">查看交易进度</view>
        </view>
        <view class="card menu-card" data-page="/pages/favorite-list/index" bindtap="goPage">
          <view class="feature-title">我的收藏</view>
          <view class="feature-copy">仪器收藏夹</view>
        </view>
        <view class="card menu-card" data-page="/pages/chat-list/index" bindtap="goPage">
          <view class="feature-title">消息会话</view>
          <view class="feature-copy">与卖家沟通</view>
        </view>
        <view class="card menu-card" data-page="/pages/rating-list/index" bindtap="goPage">
          <view class="feature-title">我的评价</view>
          <view class="feature-copy">查看历史反馈</view>
        </view>
      </view>
    </view>
  </block>
</view>
