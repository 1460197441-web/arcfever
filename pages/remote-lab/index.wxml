<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view class="hero-panel">
    <view class="hero-title small">革命性创新：远程实验与数据服务</view>
    <view class="hero-copy">把高端设备能力转化成可订购的数据产品，用户只需要提出需求，平台负责组织实验、交付数据与代码。</view>
    <view class="hero-actions">
      <view class="ghost-btn" bindtap="goEquipment">返回设备广场</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view>
        <view class="section-title">服务套餐</view>
        <view class="section-subtitle">适合从个人研究到企业委托的不同场景</view>
      </view>
    </view>
    <view class="list-stack">
      <view class="card package-card" wx:for="{{packages}}" wx:key="title">
        <view class="feature-top">
          <view class="feature-title">{{item.title}}</view>
          <view class="feature-price">{{item.price}}</view>
        </view>
        <view class="feature-copy">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view>
        <view class="section-title">服务流程</view>
        <view class="section-subtitle">需求提交到报告交付的标准闭环</view>
      </view>
    </view>
    <view class="card package-card">
      <view class="bullet-row"><view class="bullet-dot"></view><view class="bullet-text">提交实验主题、目标和样本信息</view></view>
      <view class="bullet-row"><view class="bullet-dot"></view><view class="bullet-text">平台匹配设备与实验服务方并确认排期</view></view>
      <view class="bullet-row"><view class="bullet-dot"></view><view class="bullet-text">服务方执行实验并同步关键过程信息</view></view>
      <view class="bullet-row"><view class="bullet-dot"></view><view class="bullet-text">交付原始数据、标准化报告和相关分析代码</view></view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view>
        <view class="section-title">提交远程实验需求</view>
        <view class="section-subtitle">适合作为比赛答辩中的可视化业务闭环演示</view>
      </view>
    </view>
    <view class="card package-card">
      <view class="form-label">实验主题</view>
      <input class="form-input" placeholder="例如：海岸带沉积样本分析" data-field="topic" bindinput="onInput" />
      <view class="form-label">联系方式</view>
      <input class="form-input" placeholder="姓名 / 手机号 / 微信号" data-field="contact" bindinput="onInput" />
      <view class="form-label">需求说明</view>
      <textarea class="form-textarea" placeholder="填写样本情况、指标需求、期望交付物" data-field="requirement" bindinput="onInput"></textarea>
      <view class="primary-btn full-btn" bindtap="submitRequest">提交远程实验需求</view>
    </view>
  </view>
</view>
