<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view class="hero-panel">
    <view class="hero-title small">科学社区与专业交流平台</view>
    <view class="hero-copy">以前期科研工作者实名交流为核心，承接设备共享经验、项目协作案例和 AI 工具使用反馈，持续沉淀平台信任。</view>
  </view>

  <view class="section">
    <view class="chip-row">
      <view
        wx:for="{{tags}}"
        wx:key="*this"
        class="chip {{activeTag === item ? 'active' : ''}}"
        data-tag="{{item}}"
        bindtap="chooseTag"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">正在获取社区内容...</view>
  <view wx:elif="{{!filteredList.length}}" class="empty-state">当前标签下暂无内容。</view>

  <view wx:else class="section list-stack">
    <view class="card post-item" wx:for="{{filteredList}}" wx:key="id" data-id="{{item.id}}" bindtap="openPost">
      <view class="chip tag-chip">{{item.tag}}</view>
      <view class="feature-title">{{item.title}}</view>
      <view class="feature-copy">{{item.excerpt}}</view>
      <view class="post-meta">{{item.author}} · {{item.likes}} 赞 · {{item.comments}} 评论</view>
    </view>
  </view>
</view>
