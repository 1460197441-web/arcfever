<view class="page-shell">
  <view class="nav-row"><view class="back-btn" bindtap="goBack">‹</view></view>
  <view class="hero-panel">
    <view class="hero-tag">历史评价</view>
    <view class="hero-title">查看和补充你的反馈</view>
    <view class="hero-actions">
      <view class="primary-btn" bindtap="goPublish">发布评价</view>
    </view>
  </view>
  <view class="section list-stack">
    <view class="card panel" wx:for="{{list}}" wx:key="id">
      <view class="feature-top">
        <view class="feature-title">{{item.target}}</view>
        <view class="badge">{{item.score}} 分</view>
      </view>
      <view class="meta-text">{{item.orderId}}</view>
      <view class="feature-copy">{{item.content}}</view>
    </view>
  </view>
</view>
