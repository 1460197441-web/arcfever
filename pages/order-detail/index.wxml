<view class="page-shell">
  <view class="nav-row"><view class="back-btn" bindtap="goBack">‹</view></view>
  <view wx:if="{{!order}}" class="loading-state">正在加载订单详情...</view>
  <view wx:else class="section card panel">
    <view class="feature-title">{{instrument.name}}</view>
    <view class="meta-line">订单号：{{order.id}}</view>
    <view class="meta-line">状态：{{order.status}}</view>
    <view class="meta-line">买家：{{order.buyerName}}</view>
    <view class="meta-line">卖家：{{order.sellerName}}</view>
    <view class="meta-line">金额：{{order.amount}} 元</view>
    <view class="meta-line">时间：{{order.createdAt}}</view>
  </view>
</view>
