<view class="page-shell">
  <view class="nav-row">
    <view class="back-btn" bindtap="goBack">‹</view>
  </view>

  <view class="hero-panel">
    <view class="hero-title small">项目协作与人才评估平台</view>
    <view class="hero-copy">支持企业发布研发需求，平台结合硬指标与软评价，为你匹配可信赖的科研团队与个人。</view>
    <view class="hero-actions">
      <view class="ghost-btn" bindtap="goPublish">发布项目</view>
    </view>
  </view>

  <view class="section">
    <view class="chip-row">
      <view
        wx:for="{{filters}}"
        wx:key="*this"
        class="chip {{activeFilter === item ? 'active' : ''}}"
        data-filter="{{item}}"
        bindtap="chooseFilter"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">正在获取项目...</view>
  <view wx:elif="{{!filteredList.length}}" class="empty-state">当前筛选条件下暂无项目。</view>

  <view wx:else class="section list-stack">
    <view class="project-item card" wx:for="{{filteredList}}" wx:key="id" data-id="{{item.id}}" bindtap="openProject">
      <view class="feature-top">
        <view class="feature-title">{{item.title}}</view>
        <view class="status-badge">{{item.status}}</view>
      </view>
      <view class="project-domain">{{item.domain}} · {{item.owner}}</view>
      <view class="feature-copy">{{item.intro}}</view>
      <view class="chip-row">
        <view class="chip" wx:for="{{item.keywords}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="project-footer">{{item.budget}} · {{item.duration}}</view>
    </view>
  </view>
</view>
